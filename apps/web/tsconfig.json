{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@marketbrain/domain": [
        "../../packages/domain/src"
      ],
      "@marketbrain/ai": [
        "../../packages/ai/src"
      ],
      "@marketbrain/db": [
        "../../packages/db/src"
      ],
      "@marketbrain/ui": [
        "../../packages/ui/src"
      ],
      "@marketbrain/config": [
        "../../packages/config/src"
      ],
      "@marketbrain/observability": [
        "../../packages/observability/src"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".next"
  ]
}
